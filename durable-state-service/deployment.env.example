# Durable State Service deployment environment
FCA_DURABLE_STATE_SERVICE_API_KEY=replace-with-strong-shared-key
FCA_DURABLE_SERVICE_REPOSITORY_MODE=filesystem
FCA_DURABLE_SERVICE_STATE_DIR=

# Optional upstream durable authority
FCA_DATABASE_READY_STATE_API_URL=
FCA_DATABASE_READY_STATE_API_KEY=

# App-side cutover values (set on main app runtime, not this service)
# FCA_STATE_REPOSITORY_MODE=external-durable
# FCA_DURABLE_STATE_API_URL=https://<durable-service-host>
# FCA_DURABLE_STATE_API_KEY=replace-with-strong-shared-key
