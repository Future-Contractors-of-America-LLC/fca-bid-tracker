{
  "routes": [
    {
      "route": "/api/*",
      "rewrite": "/api/*",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/deployment-status.json",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/domain-continuity.json",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/runtime-fingerprint.txt",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "Content-Type": "text/plain; charset=utf-8"
      }
    },
    {
      "route": "/live-shell-verification.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/host-binding-audit.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/api-continuity-audit.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    },
    {
      "route": "/commit-witness-*.txt",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "Content-Type": "text/plain; charset=utf-8"
      }
    },
    {
      "route": "/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    }
  ],
  "globalHeaders": {
    "X-Auricrux-Deployment-Intent": "live-login-and-public-shell-verification"
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.gif",
      "/*.svg",
      "/*.ico",
      "/*.txt",
      "/favicon.ico",
      "/deployment-status.json",
      "/domain-continuity.json",
      "/runtime-fingerprint.txt",
      "/live-shell-verification.html",
      "/host-binding-audit.html",
      "/api-continuity-audit.html"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate"
      }
    }
  }
}
